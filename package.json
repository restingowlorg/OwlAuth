{
  "name": "@restingowlorg/ossec-auth",
  "version": "1.0.1",
  "description": "Multi-platform, OWASP-aligned authentication framework",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mongo": "./dist/infra/databases/mongo/mongo.js",
    "./postgres": "./dist/infra/databases/postgresql/postgres.js"
  },
  "scripts": {
    "build": "tsc --declaration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.js src/",
    "lint:fix": "eslint --fix --ext .ts,.js src/",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md}\"",
    "prepare": "husky"
  },
  "keywords": [
    "authentication",
    "auth",
    "auth-library",
    "node-auth",
    "framework-agnostic",
    "backend-auth",
    "session-auth",
    "password-auth",
    "magic-link",
    "passwordless",
    "login",
    "signup",
    "security",
    "user-auth",
    "nodejs",
    "typescript",
    "clean-architecture",
    "hexagonal-architecture",
    "backend",
    "api-auth",
    "express-auth",
    "nest-auth"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@zxcvbn-ts/core": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "js-sha1": "^0.7.0",
    "mongodb": "^7.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@secretlint/quick-start": "^8.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "^8.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/js-sha1": "^0.6.3",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "secretlint": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist"
  ]
}
