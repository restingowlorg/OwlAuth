{
  "name": "@restingowlorg/owlauth",
  "version": "1.0.1",
  "description": "owl-auth: OWASP-informed authentication primitives for Node.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/restingowlorg/OwlAuth.git"
  },
  "bugs": {
    "url": "https://github.com/restingowlorg/OwlAuth/issues"
  },
  "homepage": "https://github.com/restingowlorg/OwlAuth#readme",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mongo": {
      "types": "./dist/infra/databases/mongo/mongo.d.ts",
      "default": "./dist/infra/databases/mongo/mongo.js"
    },
    "./postgres": {
      "types": "./dist/infra/databases/postgresql/postgres.d.ts",
      "default": "./dist/infra/databases/postgresql/postgres.js"
    }
  },
  "scripts": {
    "build": "tsc --declaration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.js src/",
    "lint:fix": "eslint --fix --ext .ts,.js src/",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md}\"",
    "test": "jest",
    "prepare": "is-ci || husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:validate": "npm run format:check && npm run lint -- --max-warnings=0 && npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "authentication",
    "auth",
    "auth-library",
    "node-auth",
    "framework-agnostic",
    "backend-auth",
    "session-auth",
    "password-auth",
    "magic-link",
    "passwordless",
    "login",
    "signup",
    "security",
    "user-auth",
    "nodejs",
    "typescript",
    "clean-architecture",
    "hexagonal-architecture",
    "backend",
    "api-auth",
    "express-auth",
    "nest-auth"
  ],
  "author": {
    "name": "Resting Owl",
    "url": "https://github.com/restingowlorg"
  },
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@zxcvbn-ts/core": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "mongodb": "^7.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@secretlint/quick-start": "^8.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "^8.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "secretlint": "^8.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist"
  ]
}
